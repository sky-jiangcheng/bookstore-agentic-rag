
# Google AI API Key for Gemini
GOOGLE_API_KEY=your_google_api_key_here

# Neon / Vercel Postgres
DATABASE_URL=your_neon_or_vercel_postgres_url_here

# Upstash Vector
UPSTASH_VECTOR_REST_URL=your_upstash_vector_url_here
UPSTASH_VECTOR_REST_TOKEN=your_upstash_vector_token_here

# Upstash Redis
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# Transitional external services (optional during migration)
AUTH_SERVICE_URL=
CATALOG_SERVICE_URL=

# Next.js public
NEXT_PUBLIC_APP_URL=http://localhost:3000
