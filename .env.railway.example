# Vercel 环境变量 - Railway 后端服务
# 将此文件内容复制到 Vercel 项目设置中

# ============================================================================
# Railway 服务 URLs（部署后从 Railway 控制台获取实际值）
# ============================================================================

# API Gateway
GATEWAY_URL=https://bookstore-gateway.up.railway.app

# 认证服务
AUTH_URL=https://bookstore-auth.up.railway.app

# 书目服务
CATALOG_URL=https://bookstore-catalog.up.railway.app

# 运营服务
OPS_URL=https://bookstore-ops.up.railway.app

# ============================================================================
# 数据库连接（如果 Vercel 需要直连数据库）
# ============================================================================

# PostgreSQL（从 Railway 获取）
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# Redis（从 Railway 获取）
# REDIS_URL=${{Redis.REDIS_URL}}

# ============================================================================
# API 密钥
# ============================================================================

# Google AI API 密钥（Gemini）
GOOGLE_API_KEY=your-google-api-key

# ============================================================================
# 配置选项
# ============================================================================

# 环境标识
ENVIRONMENT=production
RAILWAY_DEPLOYMENT=true

# 日志级别
LOG_LEVEL=info

# ============================================================================
# 配置说明
# ============================================================================

# 1. 在 Railway 部署完成后，获取各服务的实际域名
# 2. 在 Vercel 项目设置中添加以上环境变量
# 3. 更新 *_URL 变量为实际的 Railway 服务地址
# 4. 重新部署 Vercel 项目使环境变量生效
