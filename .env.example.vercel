# Vercel Environment Variables for BookStore RAG
# Copy these to your Vercel project settings

# ============================================================================
# Required: AI/LLM
# ============================================================================
GOOGLE_API_KEY=your_google_api_key_here

# ============================================================================
# Required: Database (Vercel Postgres)
# ============================================================================
POSTGRES_URL=your_vercel_postgres_url
POSTGRES_PRISMA_URL=your_vercel_postgres_url

# ============================================================================
# Required: Vercel KV (for caching and conversation memory)
# ============================================================================
KV_URL=your_vercel_kv_url
KV_REST_API_URL=your_vercel_kv_rest_url
KV_REST_API_TOKEN=your_vercel_kv_rest_api_token

# ============================================================================
# Optional: External Services (if not using Vercel KV)
# ============================================================================
# UPSTASH_VECTOR_REST_URL=
# UPSTASH_VECTOR_REST_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ============================================================================
# Optional: Reranker Configuration
# ============================================================================
# RERANKER_ENABLED=false
# RERANKER_TYPE=api
# COHERE_API_KEY=your_cohere_api_key

# ============================================================================
# Optional: Feature Flags
# ============================================================================
# ENABLE_FEEDBACK=true
# ENABLE_CONVERSATION_MEMORY=true
# CHUNKING_STRATEGY=book-specific
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64

# ============================================================================
# Vercel Specific
# ============================================================================
VERCEL_USE_SIMPLIFIED=true
VERCEL_TIMEOUT=9000
